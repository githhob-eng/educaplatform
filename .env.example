# ===========================
# BASE DE DATOS
# ===========================
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/educaplatform"

# ===========================
# AUTENTICACIÓN
# ===========================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRE_IN="24h"
JWT_REFRESH_EXPIRE_IN="7d"

# ===========================
# SERVIDOR
# ===========================
NODE_ENV="development"
PORT=3000
API_URL="http://localhost:3000"
API_PORT=3001

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================
# GOOGLE DRIVE (Para almacenar archivos)
# ===========================
# Crear Service Account en Google Cloud Console
GOOGLE_DRIVE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_DRIVE_PROJECT_ID="your-project-id"
GOOGLE_DRIVE_FOLDER_ID="root" # ID de la carpeta raíz donde guardar cursos

# ===========================
# YOUTUBE (Para almacenar videos)
# ===========================
YOUTUBE_API_KEY="your-youtube-api-key"
YOUTUBE_CHANNEL_ID="your-channel-id"

# ===========================
# PAGOS (Shopify)
# ===========================
SHOPIFY_STORE_NAME="your-store-name"
SHOPIFY_API_KEY="your-shopify-api-key"
SHOPIFY_API_PASSWORD="your-shopify-api-password"
SHOPIFY_WEBHOOK_SECRET="your-webhook-secret"
SHOPIFY_REDIRECT_URL="http://localhost:3000/dashboard/teacher/payments/callback"

# ===========================
# PAGOS (TiendaNube)
# ===========================
TIENDANUBE_STORE_ID="your-store-id"
TIENDANUBE_API_KEY="your-api-key"
TIENDANUBE_WEBHOOK_SECRET="your-webhook-secret"

# ===========================
# EMAIL (Para notificaciones)
# ===========================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@educaplatform.com"
SMTP_FROM_NAME="EducaPlatform"

# ===========================
# CLOUDINARY (Para images CDN)
# ===========================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ===========================
# REDIS (Para cache y sesiones)
# ===========================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ===========================
# STRIPE (Alternativa para pagos)
# ===========================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ===========================
# LOGS Y MONITORING
# ===========================
LOG_LEVEL="info"
SENTRY_DSN=""

# ===========================
# COOKIES
# ===========================
COOKIE_SECURE=false # true en producción
COOKIE_SAME_SITE="lax"
COOKIE_DOMAIN="localhost"

# ===========================
# CORS
# ===========================
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
CORS_CREDENTIALS=true

# ===========================
# STRIPE PRODUCTS (precios de slots)
# ===========================
STRIPE_PRODUCT_5_SLOTS="prod_..."
STRIPE_PRODUCT_10_SLOTS="prod_..."
STRIPE_PRODUCT_20_SLOTS="prod_..."

# ===========================
# TWILIO (SMS para notificaciones)
# ===========================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ===========================
# VERCEL (Deployment)
# ===========================
VERCEL_URL=""

# ===========================
# GITHUB (Para webhooks de deployment)
# ===========================
GITHUB_WEBHOOK_SECRET=""

# ===========================
# TIMEZONE
# ===========================
TZ="America/Argentina/Buenos_Aires"
